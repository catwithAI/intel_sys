# ==============================================================================
# Intel System 配置文件
# 复制为 .env 后填入实际值
# ==============================================================================

# ------------------------------------------------------------------------------
# Redis 连接
# ------------------------------------------------------------------------------
# 用于存储市场基线数据、价格快照、Alert 去重、GitHub star 快照等状态
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# LLM 配置 (OpenRouter)
# ------------------------------------------------------------------------------
# OpenRouter API 基地址
OPENAI_API_BASE=https://openrouter.ai/api/v1
# OpenRouter API Key，在 https://openrouter.ai/keys 申请
OPENROUTER_API_KEY=sk-or-v1-xxxxx
# 使用的模型 ID
OPENROUTER_MODEL=google/gemini-3-flash-preview

# ------------------------------------------------------------------------------
# GitHub 信源配置
# ------------------------------------------------------------------------------
# GitHub Personal Access Token，用于 Search API（未认证限速 10 req/min，认证后 30 req/min）
GITHUB_TOKEN=ghp_xxxxx

# 监控的 GitHub Topics 列表（JSON 数组格式）
# 系统每日通过 Search API 查询这些 topic 下按 star 排序的项目
GITHUB_TOPICS=["ai","infrastructure","llm"]

# 每个 topic 从 Search API 拉取的项目数量
# 总观测池大小 = pool_size_per_topic * len(topics)
# 值越大覆盖面越广，但 API 消耗越多
GITHUB_POOL_SIZE_PER_TOPIC=250

# Star-delta 异常检测阈值
#
# 算法说明：
#   每次运行时记录每个项目的 star 数快照到 Redis（key: gh:repo:{name}:star_snapshot, TTL 30天）
#   下次运行时计算 delta = 当前 star 数 - 上次快照 star 数
#   当 delta >= 该阈值时，判定为"star 增长异常"，进入候选列表
#
# 示例：阈值=50 表示两次运行间（默认间隔 24h）star 增长 >= 50 才触发
# 首次运行无历史快照，不会产生任何异常（仅写入基线）
GITHUB_STAR_DELTA_THRESHOLD=50

# gtrending 补充采集的编程语言列表（JSON 数组格式）
# 系统从 GitHub Trending 页面抓取这些语言的每日 trending 项目，作为 Search API 的补充信号
# 所有 gtrending 项目直接进入候选池（不再做 topic 过滤），与 star-delta 结果合并去重
GITHUB_GTRENDING_LANGUAGES=["python","typescript","rust","go"]

# gtrending 最低 period stars 过滤
# 仅保留当日 trending stars >= 该值的项目，过滤低质量噪声
GITHUB_GTRENDING_MIN_PERIOD_STARS=20

# ------------------------------------------------------------------------------
# Polymarket 预测市场异常检测配置
# ------------------------------------------------------------------------------
# 规则每 30 秒执行一次，对所有活跃市场计算三类异动信号的综合评分：
#   anomaly_score = volume_score * 0.4 + imbalance_score * 0.3 + velocity_score * 0.3
# 任一信号触发即进入 AI 分析，24 小时内同一市场不重复告警

# --- 信号 1: 成交量突增 (Volume Spike) ---
# 算法：volume_ratio = volume_24h / avg_volume_7d
#   avg_volume_7d 使用指数移动平均(EMA)更新：new_avg = old_avg * 0.85 + current * 0.15
#   当 volume_ratio >= 该阈值时触发
#   信号评分：min(volume_ratio / 10, 1.0)
#
# 示例：阈值=3.0 表示 24h 成交量达到 7 日均值的 3 倍时触发
#   如果 7 日均量 $10,000，则 24h 成交量 >= $30,000 触发
PM_VOLUME_SPIKE_RATIO=3.0

# --- 信号 2: Orderbook 失衡 (Book Imbalance) ---
# 算法：imbalance = total_bid_size / (total_bid_size + total_ask_size)  （取前 10 档）
#   正常市场 imbalance 接近 0.5（买卖平衡）
#   当 imbalance >= HIGH 或 imbalance <= LOW 时触发
#   信号评分：abs(imbalance - 0.5) * 2（偏离中值的程度，范围 0~1）
#
# HIGH=0.7: 买方挂单量占比 >= 70%，说明有大量买盘堆积（可能是知情交易者看涨）
# LOW=0.3:  卖方挂单量占比 >= 70%，说明有大量卖盘堆积（可能是知情交易者看跌）
PM_BOOK_IMBALANCE_HIGH=0.7
PM_BOOK_IMBALANCE_LOW=0.3

# --- 信号 3: 价格急速变动 (Price Velocity) ---
# 算法：price_change_pct = |current_price - last_price| / last_price * 100
#   last_price 存储在 Redis（key: pm:market:{id}:last_price, TTL 1h）
#   当 price_change_pct >= 该阈值时触发
#   信号评分：min(price_change_pct / 20, 1.0)
#
# 示例：阈值=5.0 表示价格在两次检测间（默认间隔 30 秒）变动 >= 5% 触发
#   从 0.60 变到 0.63 (5%) 会触发
PM_PRICE_VELOCITY_PCT=5.0

# 价格速度的检测窗口（分钟），当前版本用于 Redis 快照 TTL 计算
# 快照 TTL = 1 小时，每 30 秒更新一次，实际比较的是相邻两次检测间的价格变化
PM_PRICE_VELOCITY_WINDOW_MIN=15

# --- 数据采集调优 ---
# 按 volume24hr 降序排序后取前 N 个市场进行监控
# 值越大覆盖面越广，但 CLOB API 请求量 ≈ N × 2(tokens/market) × 2(orderbook+midpoint)
# CLOB 限速 100 req/min，默认 25 市场 ≈ 100 请求/轮，与限速持平
PM_TOP_MARKETS=25

# CLOB API 并发请求信号量上限
# 控制同时发出的 CLOB 请求数量，避免瞬时并发过高
# 429 (Too Many Requests) 时自动读 Retry-After header 重试（最多 2 次）
PM_CLOB_CONCURRENCY=8

# ------------------------------------------------------------------------------
# 飞书 Webhook 机器人
# ------------------------------------------------------------------------------
# 飞书群自定义机器人 Webhook 地址
# 为空则不推送飞书消息，仅保留 API Endpoint 查询
FEISHU_WEBHOOK_URL=
# 签名校验密钥（可选）。在飞书机器人"安全设置"中开启"签名校验"后填入
FEISHU_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Alert 存储
# ------------------------------------------------------------------------------
# 每个信源（github / polymarket）在 Redis 中保留的最大 alert 数量
# 使用 LPUSH + LTRIM 实现环形缓冲，超出后最旧的 alert 被自动丢弃
ALERT_MAX_PER_SOURCE=100
